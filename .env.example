# Backend URL

# Supabase Postgres connection string (use Connection Pooler in Supabase dashboard).
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.nlfyukpqnqbwznpyufzd:[PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres.nlfyukpqnqbwznpyufzd:[PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:5432/postgres"



# Supabase (Auth). Publishable key from Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Comma-separated list of emails allowed to access the dashboard (admin whitelist).
ALLOWED_ADMIN_EMAILS=admin-user@example.com,admin-other@example.com

